<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>Novo item - Painel do administrador</title>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="conteudo">
    <p><a href="/admin">&larr; Voltar ao painel</a></p>
    <h1>Novo item de leilao</h1>
    <% if (erro) { %>
      <p class="mensagem-erro"><%= erro %></p>
    <% } %>
    <form action="/admin/itens" method="POST" class="formulario-item">
      <label for="nome">Nome</label>
      <input type="text" name="nome" id="nome" required maxlength="120" />

      <label for="descricao">Descricao</label>
      <textarea name="descricao" id="descricao" rows="4"></textarea>

      <label for="imagemUrl">URL da imagem (opcional)</label>
      <input type="url" name="imagemUrl" id="imagemUrl" />

      <label for="lanceInicial">Lance inicial (R$)</label>
      <input type="number" step="0.01" min="0" name="lanceInicial" id="lanceInicial" required />

      <label for="incrementoMinimo">Incremento minimo por lance (R$)</label>
      <input type="number" step="0.01" min="0" name="incrementoMinimo" id="incrementoMinimo" value="0" />

      <label for="dataEncerramento">Data/hora de encerramento (opcional)</label>
      <input type="datetime-local" name="dataEncerramento" id="dataEncerramento" />

      <button type="submit">Publicar item</button>
    </form>
  </main>
</body>
</html>
